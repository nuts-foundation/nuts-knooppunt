# Dezi OIDC Client Configuration

# Dezi authentication platform URL
DEZI_AUTHORITY=https://acceptatie.auth.dezi.nl

# Client ID registered with Dezi
DEZI_CLIENT_ID=cb96e3fb-394c-4d12-b2b2-7a1a7bbe0b02

# OAuth callback URL (must match what's registered with Dezi)
DEZI_REDIRECT_URI=http://localhost:8090/callback

# Server port
SERVER_PORT=8090

# Certificate files for signing JWT bearer token and JWE decryption (userinfo object)
KEY_FILE=./cert-key.pem

# Frontend URL for CORS and redirects
FRONTEND_BASE_URL=http://localhost:3000

