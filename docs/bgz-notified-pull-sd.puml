@startuml

title BgZ Verwijzing: Notified Pull

box "Sending XIS (Verwijzende partij)"
    actor User as "Clinician"
    participant ehr_s as "EHR\n[ FHIR ]"
    participant kp_s as "Knooppunt"
end box

box "Addressing (mCSD)"
    participant mcsd_s as "mCSD Admin Directory (sender)"
    participant mcsd_r as "mCSD Admin Directory (receiver)"
end box

box "Receiving XIS (Ontvangende partij)"
    participant kp_r as "Knooppunt"
    participant ehr_r as "EHR\n[ FHIR ]"
end box

== Step 0: mCSD population ==

ehr_r -> mcsd_r : [FHIR R4] POST /Organization\n[FHIR R4] POST /HealthcareService (relevant for the BgZ use-case)\n[FHIR R4] POST /Endpoint\n(Endpoint.payloadType = Twiin-TA-notification)

ehr_s -> mcsd_s : [FHIR R4] POST /Organization\n[FHIR R4] POST /Endpoint\n(Endpoint.payloadType = http://nictiz.nl/fhir/CapabilityStatement/bgz2017-servercapabilities)

mcsd_s <-> mcsd_r : sync (via knoppunt)

== Step 1: Create BgZ Workflow Task at sending party ==

User -> ehr_s : Initiate BgZ referral

activate ehr_s

ehr_s -> ehr_s : [FHIR STU3] POST /Task

note over ehr_s, kp_r
Workflow Task, Profile: http://nictiz.nl/fhir/StructureDefinition/BgZ-verwijzing-Task, contains
- status=requested
- intent=proposal
- code=3457005 "verwijzen van patiënt"
- input=[FHIR query parameters per BgZ dataset]
end note
deactivate kp_s

== Step 2: Locate notification endpoint of receiving party ==
'http://fhir.nl/fhir/NamingSystem/ura
ehr_s -> mcsd_s : [FHIR R4] GET /HealthcareService?type=desired-type (i.e. 504, Multidisciplinary Ca))
ehr_s -> mcsd_s : [FHIR R4] GET required endpoint connected to this HealthcareService, i.e. through HealthcareService.endpoint\nwhere Endpoint.payloadType = Twiin-TA-notification
activate mcsd_s
    mcsd_s --> ehr_s : 200 OK\n(HealthcareService + Endpoints)
deactivate mcsd_s

ehr_s -> ehr_s : Select endpoint\nwith type=Twiin-TA-notification

== Step 3: Send Notified Pull task to receiving party ==

note over ehr_s, kp_r
  Notification Task (pull-notification) contains:
  - code.coding=pull-notification, http://fhir.nl/fhir/NamingSystem/TaskCode
  - requester.onBehalfOf.identifier = sending org URA (system: http://fhir.nl/fhir/NamingSystem/ura)
  - owner.identifier = receiving org URA (system: http://fhir.nl/fhir/NamingSystem/ura)
  - basedOn = Task/{workflow-task-id}
  - input[authorization-base] = OAuth authorization base URL
  - input[get-workflow-task] = true
end note

ehr_s -> ehr_r : [FHIR STU3] POST {notification-endpoint}/Task
activate ehr_r
    ehr_r --> ehr_s : 201 Created\n(Task/{notification-task-id})
deactivate ehr_r

deactivate ehr_s

== Step 4: Locate BgZ Server endpoint of sending party ==

ehr_r->ehr_r: Read notification Task;\nextract requester.onBehalfOf.Identifier
ehr_r -> mcsd_r : [FHIR R4] GET /Organization?identifier=http://fhir.nl/fhir/NamingSystem/ura|extracted-ura
activate mcsd_r
    mcsd_r --> ehr_r : 200 OK\n(Organization)
deactivate mcsd_r
ehr_r->ehr_r: Find Organization.endpoint where\nEndpoint.payloadType=\nhttp://nictiz.nl/fhir/CapabilityStatement/bgz2017-servercapabilities\n(with loop read-ing Organization.endpoint references)

== Step 5: Receiving party pulls BgZ Workflow Task ==

ehr_r -> kp_r : Get access token for sending party\n[OAuth2] client_credentials / JWT grant
activate kp_r
    kp_r --> ehr_r : 200 OK\n(access_token, scope=bgz-sender)
deactivate kp_r

ehr_r -> kp_s : [FHIR STU3] GET /Task/{workflow-task-id}\nAuthorization: Bearer {access_token}
ehr_r -> ehr_r : Read notification Task;\nextract basedOn = Task/{workflow-task-id}\nand authorization-base
activate kp_s
    kp_s -> kp_s : Validate access token\nEvaluate policy (PDP)
    kp_s -> ehr_s : [FHIR STU3] GET /Task/{workflow-task-id}
    activate ehr_s
        ehr_s --> kp_s : 200 OK\n(Task with BgZ FHIR query inputs)
    deactivate ehr_s
    kp_s --> ehr_r : 200 OK\n(Task)
deactivate kp_s

== Step 6: Receiving party pulls BgZ dataset ==

ehr_r -> ehr_r : Extract FHIR query parameters\nfrom Task.input (BgZ dataset queries)

loop For each BgZ FHIR query in Task.input
    ehr_r -> kp_s : [FHIR STU3] GET /{resource}?{query}\nAuthorization: Bearer {access_token}
    activate kp_s
        kp_s -> kp_s : Validate access token\nEvaluate policy (PDP)
        kp_s -> ehr_s : [FHIR STU3] GET /{resource}?{query}
        activate ehr_s
            ehr_s --> kp_s : 200 OK\n(Bundle)
        deactivate ehr_s
        kp_s --> ehr_r : 200 OK\n(Bundle)
    deactivate kp_s
end

ehr_r --> ehr_r : Process incoming BgZ dataset

@enduml