  <diagram id="idtjW06T05RA1R8AXaPS" name="DeziUserCredential">
    <mxGraphModel dx="1686" dy="1209" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="&lt;div style=&quot;background-color: rgb(255, 255, 255); color: rgb(8, 8, 8); font-size: 16px;&quot;&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:9,8pt;&quot;&gt;{&lt;br&gt;  &lt;span style=&quot;color:#871094;&quot;&gt;&quot;@context&quot;&lt;/span&gt;: [&lt;br&gt;    &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;https://www.w3.org/2018/credentials/v1&quot;&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#067d17;&quot;&gt;  &lt;/span&gt;],&lt;br&gt;  &lt;span style=&quot;color:#871094;&quot;&gt;&quot;id&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;61b1fafc-4ec7-4489-a280-8d0a50a3d5a9&quot;&lt;/span&gt;,&lt;br&gt;  &lt;span style=&quot;color:#871094;&quot;&gt;&quot;type&quot;&lt;/span&gt;: [&lt;br&gt;    &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;VerifiableCredential&quot;&lt;/span&gt;,&lt;br&gt;    &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;DeziUserCredential&quot;&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#067d17;&quot;&gt;  &lt;/span&gt;],&lt;br&gt;  &lt;span style=&quot;color:#871094;&quot;&gt;&quot;issuer&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;abonnee.dezi.nl&quot;&lt;/span&gt;,&lt;br&gt;  &lt;span style=&quot;color:#871094;&quot;&gt;&quot;issuanceDate&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;2024-11-21T09:46:16Z&quot;&lt;/span&gt;,&lt;br&gt;  &lt;span style=&quot;color:#871094;&quot;&gt;&quot;expirationDate&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;2025-02-21T09:46:16Z&quot;&lt;/span&gt;,&lt;br&gt;  &lt;span style=&quot;color:#871094;&quot;&gt;&quot;credentialSubject&quot;&lt;/span&gt;: {&lt;br&gt;    &lt;span style=&quot;color:#871094;&quot;&gt;&quot;@type&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;DeziIDTokenSubject&quot;&lt;/span&gt;,&lt;br&gt;    &lt;span style=&quot;color:#871094;&quot;&gt;&quot;identifier&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;87654321&quot;&lt;/span&gt;,&lt;br&gt;    &lt;span style=&quot;color:#871094;&quot;&gt;&quot;name&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;Zorgaanbieder&quot;&lt;/span&gt;,&lt;br&gt;    &lt;span style=&quot;color:#871094;&quot;&gt;&quot;employee&quot;&lt;/span&gt;: {&lt;br&gt;      &lt;span style=&quot;color:#871094;&quot;&gt;&quot;@type&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;HealthcareWorker&quot;&lt;/span&gt;,&lt;br&gt;      &lt;span style=&quot;color:#871094;&quot;&gt;&quot;identifier&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;123456789&quot;&lt;/span&gt;,&lt;br&gt;      &lt;span style=&quot;color:#871094;&quot;&gt;&quot;initials&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;A.B.&quot;&lt;/span&gt;,&lt;br&gt;      &lt;span style=&quot;color:#871094;&quot;&gt;&quot;surnamePrefix&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;&quot;&lt;/span&gt;,&lt;br&gt;      &lt;span style=&quot;color:#871094;&quot;&gt;&quot;surname&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;Zorgmedewerker&quot;&lt;/span&gt;,&lt;br&gt;      &lt;span style=&quot;color:#871094;&quot;&gt;&quot;role&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;01.000&quot;&lt;/span&gt;,&lt;br&gt;      &lt;span style=&quot;color:#871094;&quot;&gt;&quot;role_name&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;Arts&quot;&lt;/span&gt;,&lt;br&gt;      &lt;span style=&quot;color:#871094;&quot;&gt;&quot;role_registry&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;http://www.dezi.nl/rol_code_bron/big&quot;&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#067d17;&quot;&gt;    &lt;/span&gt;}&lt;br&gt;  },&lt;br&gt;  &lt;span style=&quot;color:#871094;&quot;&gt;&quot;proof&quot;&lt;/span&gt;: {&lt;br&gt;    &lt;span style=&quot;color:#871094;&quot;&gt;&quot;type&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;DeziIDJWT07&quot;&lt;/span&gt;,&lt;br&gt;    &lt;span style=&quot;color:#871094;&quot;&gt;&quot;jwt&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;eyJhbGciOiJSUzI1NiIsImtpZCI6IjMyN...FomAeSlU_zZp6UojVIOnCY2gL5EMc_8B1PDC6R_C--quGoh14jiSOJAeYSf_9ETjgQ&quot;&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#067d17;&quot;&gt;  &lt;/span&gt;}&lt;br&gt;}&lt;br&gt;&lt;/pre&gt;&lt;/div&gt;" link="&lt;div style=&quot;background-color:#ffffff;color:#080808&quot;&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:9,8pt;&quot;&gt;{&lt;br&gt;  &lt;span style=&quot;color:#871094;&quot;&gt;&quot;@context&quot;&lt;/span&gt;: [&lt;br&gt;    &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;https://www.w3.org/2018/credentials/v1&quot;&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#067d17;&quot;&gt;  &lt;/span&gt;],&lt;br&gt;  &lt;span style=&quot;color:#871094;&quot;&gt;&quot;id&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;61b1fafc-4ec7-4489-a280-8d0a50a3d5a9&quot;&lt;/span&gt;,&lt;br&gt;  &lt;span style=&quot;color:#871094;&quot;&gt;&quot;type&quot;&lt;/span&gt;: [&lt;br&gt;    &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;VerifiableCredential&quot;&lt;/span&gt;,&lt;br&gt;    &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;DeziUserCredential&quot;&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#067d17;&quot;&gt;  &lt;/span&gt;],&lt;br&gt;  &lt;span style=&quot;color:#871094;&quot;&gt;&quot;issuer&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;abonnee.dezi.nl&quot;&lt;/span&gt;,&lt;br&gt;  &lt;span style=&quot;color:#871094;&quot;&gt;&quot;issuanceDate&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;2024-11-21T09:46:16Z&quot;&lt;/span&gt;,&lt;br&gt;  &lt;span style=&quot;color:#871094;&quot;&gt;&quot;expirationDate&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;2025-02-21T09:46:16Z&quot;&lt;/span&gt;,&lt;br&gt;  &lt;span style=&quot;color:#871094;&quot;&gt;&quot;credentialSubject&quot;&lt;/span&gt;: {&lt;br&gt;    &lt;span style=&quot;color:#871094;&quot;&gt;&quot;@type&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;DeziIDTokenSubject&quot;&lt;/span&gt;,&lt;br&gt;    &lt;span style=&quot;color:#871094;&quot;&gt;&quot;identifier&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;87654321&quot;&lt;/span&gt;,&lt;br&gt;    &lt;span style=&quot;color:#871094;&quot;&gt;&quot;name&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;Zorgaanbieder&quot;&lt;/span&gt;,&lt;br&gt;    &lt;span style=&quot;color:#871094;&quot;&gt;&quot;employee&quot;&lt;/span&gt;: {&lt;br&gt;      &lt;span style=&quot;color:#871094;&quot;&gt;&quot;@type&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;HealthcareWorker&quot;&lt;/span&gt;,&lt;br&gt;      &lt;span style=&quot;color:#871094;&quot;&gt;&quot;identifier&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;123456789&quot;&lt;/span&gt;,&lt;br&gt;      &lt;span style=&quot;color:#871094;&quot;&gt;&quot;initials&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;A.B.&quot;&lt;/span&gt;,&lt;br&gt;      &lt;span style=&quot;color:#871094;&quot;&gt;&quot;surnamePrefix&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;&quot;&lt;/span&gt;,&lt;br&gt;      &lt;span style=&quot;color:#871094;&quot;&gt;&quot;surname&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;Zorgmedewerker&quot;&lt;/span&gt;,&lt;br&gt;      &lt;span style=&quot;color:#871094;&quot;&gt;&quot;role&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot;01.000&quot;&lt;/span&gt;,&lt;br&gt;      &lt;span style=&quot;color:#871094;&quot;&gt;&quot;role_name&quot;&lt;/span&gt;: &lt;span style=&quot;color:#067d17;&quot;&gt;&quot