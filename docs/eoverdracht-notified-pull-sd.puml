@startuml

title eOverdracht: Notified Pull

box "Sending XIS (Verwijzende partij)"
    actor User as "Clinician"
    participant ehr_s as "EHR\n[ FHIR Server ]"
    participant kp_s as "Knooppunt\n[ PEP / OAuth ]"
end box

box "Addressing (mCSD)"
    participant mcsd as "mCSD Directory\n[ Knooppunt ]"
end box

box "Receiving XIS (Ontvangende partij)"
    participant kp_r as "Knooppunt\n[ PEP / OAuth ]"
    participant ehr_r as "EHR\n[ FHIR Client ]"
end box

== Step 1: Create eOverdracht Task at sending party ==

User -> ehr_s : Initiate care handover

activate ehr_s

ehr_s -> ehr_s : Create eOverdracht Task\n(status=in-progress, intent=order,\ncode=308292007 "Overdracht van zorg")

ehr_s -> kp_s : [FHIR STU3] POST /Task\nProfile: eOverdracht-Task
activate kp_s
    kp_s --> ehr_s : 201 Created\n(Task/{id})
deactivate kp_s

== Step 2: Locate notification endpoint of receiving party ==

ehr_s -> mcsd : [FHIR R4] GET /Organization?identifier=URA|{ura}&_include=Organization:endpoint
activate mcsd
    mcsd --> ehr_s : 200 OK\n(Organization + Endpoints)
deactivate mcsd

ehr_s -> ehr_s : Select endpoint\nwith type=eOverdracht-notification

== Step 3: Send notification to receiving party ==

ehr_s -> kp_r : [FHIR STU3] POST {notification-endpoint}/Task/{id}
note right : Notification references the Task\ncreated at the sending party
activate kp_r
    kp_r --> ehr_s : 200 OK
deactivate kp_r

deactivate ehr_s

== Step 4: Receiving party pulls eOverdracht Task ==

ehr_r -> kp_r : Get access token for sending party\n[OAuth2] client_credentials / JWT grant
activate kp_r
    kp_r --> ehr_r : 200 OK\n(access_token, scope=eOverdracht-sender)
deactivate kp_r

ehr_r -> kp_s : [FHIR STU3] GET /Task/{id}\nAuthorization: Bearer {access_token}
activate kp_s
    kp_s -> kp_s : Validate access token\nEvaluate policy (PDP)
    kp_s -> ehr_s : [FHIR STU3] GET /Task/{id}
    activate ehr_s
        ehr_s --> kp_s : 200 OK\n(Task)
    deactivate ehr_s
    kp_s --> ehr_r : 200 OK\n(Task)
deactivate kp_s

== Step 5: Receiving party pulls clinical document (Composition) ==

ehr_r -> ehr_r : Extract Composition reference\nfrom Task.input

ehr_r -> kp_s : [FHIR STU3] GET /Composition/{id}\nAuthorization: Bearer {access_token}
activate kp_s
    kp_s -> kp_s : Validate access token\nEvaluate policy (PDP)
    kp_s -> ehr_s : [FHIR STU3] GET /Composition/{id}
    activate ehr_s
        ehr_s --> kp_s : 200 OK\n(Composition / overdrachtsbericht)
    deactivate ehr_s
    kp_s --> ehr_r : 200 OK\n(Composition / overdrachtsbericht)
deactivate kp_s

ehr_r --> ehr_r : Process incoming\ncare handover document

@enduml
